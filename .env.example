# The whole service-account JSON on ONE line. FIREBASE_SERVICE_ACCOUNT_PATH is
# no longer supported: Cloudflare Workers has no filesystem, so the key cannot
# be read from disk. Generate with:
#   jq -c . path/to/serviceAccount.json
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_ADMIN_PROJECT_ID=physioonclick
FIREBASE_ADMIN_STORAGE_BUCKET=physioonclick.firebasestorage.app

# Local emulator wiring. Set per service — they are independent, and setting
# only the auth one still points Firestore at the real production project.
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
# FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
