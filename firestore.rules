rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.email == "hello@physioonclick.co.uk"
      );
    }

    function ownsEmailResource() {
      return isSignedIn() &&
        resource.data.email is string &&
        request.auth.token.email == resource.data.email;
    }

    match /blogs/{blogId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /pricing/{pricingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /exerciseVideos/{videoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /rehabPrograms/{programId} {
      allow read: if isAdmin() ||
        (isSignedIn() &&
          resource.data.patientEmail is string &&
          request.auth.token.email == resource.data.patientEmail);
      allow create, update, delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      // Bookings are only ever created server-side (Cal.com webhook, appointments/sync,
      // link-bookings), all via the Admin SDK which bypasses these rules. No legitimate
      // client path creates a booking directly, so client-side create is fully denied.
      allow create: if false;
      allow read: if isAdmin() || ownsEmailResource() ||
        (isSignedIn() && resource.data.bookedBy == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /dependents/{dependentId} {
      // Mirrors client-side caps in lib/validation.ts / mobile validators.dart.
      // dob is a 10-char ISO date and relationship a short picklist value; the
      // caps just stop a hand-crafted client SDK write storing megabyte strings.
      function validDependent(d) {
        return d.keys().hasOnly(['ownerId', 'name', 'dob', 'relationship', 'notes',
            'avatarUrl', 'createdAt']) &&
          d.name is string && d.name.size() >= 2 && d.name.size() <= 80 &&
          d.dob is string && d.dob.size() <= 30 &&
          d.relationship is string && d.relationship.size() <= 50 &&
          d.notes is string && d.notes.size() <= 500;
      }
      function ownsDependent() {
        return isSignedIn() && resource.data.ownerId == request.auth.uid;
      }
      // Split so create/update always run validDependent — an unconstrained
      // `allow write: if isAdmin()` would OR past it (rules grant if ANY matches).
      allow read, delete: if isAdmin() || ownsDependent();
      // ownerId is pinned immutable on update — ownsDependent() only checks the
      // pre-update ownerId, so without this an owner could re-point their own
      // dependent doc at a victim uid and plant data inside a stranger's account.
      allow update: if (isAdmin() || ownsDependent()) &&
        request.resource.data.ownerId == resource.data.ownerId &&
        validDependent(request.resource.data);
      allow create: if (isAdmin() ||
        (isSignedIn() && request.resource.data.ownerId == request.auth.uid)) &&
        validDependent(request.resource.data);
    }

    match /sessionSummaries/{summaryId} {
      // Normally created server-side (publishSummary, Admin SDK bypasses rules);
      // these constraints cover any direct admin-client write path.
      function validSummary(d) {
        return d.workedOn is string && d.workedOn.size() >= 1 && d.workedOn.size() <= 2000 &&
          d.exercises is string && d.exercises.size() >= 1 && d.exercises.size() <= 2000 &&
          d.nextSteps is string && d.nextSteps.size() >= 1 && d.nextSteps.size() <= 2000 &&
          d.sessionOutcome in ['improving', 'stable', 'setback'] &&
          d.recoveryPercent is int && d.recoveryPercent >= 0 && d.recoveryPercent <= 100 &&
          d.painScore is number && d.painScore >= 0 && d.painScore <= 10 &&
          d.followUpWeeks is number && d.followUpWeeks >= 0;
      }
      allow read: if isSignedIn() && (
        isAdmin() ||
        get(/databases/$(database)/documents/bookings/$(resource.data.bookingId)).data.bookedBy == request.auth.uid
      );
      allow create, update: if isAdmin() && validSummary(request.resource.data);
      allow delete: if isAdmin();
    }

    match /pendingSelections/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      // Not currently written or read anywhere in the app (Stripe Checkout doesn't
      // mirror payment records to Firestore). Admin-only until a real writer exists,
      // rather than leaving client-writable "payment succeeded" records unused.
      allow read, write: if isAdmin();
    }

    match /enquiries/{enquiryId} {
      // Create is public (anonymous contact form + the client-SDK fallback in
      // lib/firestore-helpers.ts), so it enforces the same caps/format/enum as
      // app/api/enquiry, plus a key allow-list to stop arbitrary-field injection.
      // Email regex mirrors EMAIL_RE in lib/validation.ts.
      function validNewEnquiry(d) {
        return d.status == 'new' &&
          d.keys().hasOnly(['name', 'email', 'emailLower', 'phone', 'service',
            'message', 'status', 'source', 'userId', 'patientRef', 'createdAt']) &&
          d.name is string && d.name.size() >= 2 && d.name.size() <= 80 &&
          d.email is string && d.email.size() <= 254 &&
          d.email.matches('^[^@\\s]+@[^@\\s]+[.][^@\\s]+$') &&
          d.phone is string && d.phone.size() <= 20 &&
          // `service` is a reserved word in the rules language — bracket-access it.
          d['service'] is string && d['service'].size() >= 1 && d['service'].size() <= 200 &&
          d.message is string && d.message.size() >= 20 && d.message.size() <= 2000;
      }
      allow create: if validNewEnquiry(request.resource.data);
      allow read: if isAdmin() || ownsEmailResource();
      allow update: if isAdmin() &&
        request.resource.data.status in ['new', 'in-progress', 'resolved'];
      allow delete: if isAdmin();
    }

    match /patients/{userId} {
      allow read, update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /patients/{userId}/people/{personId}/clinicalAssessments/{date} {
      // Shape written by lib/recovery.ts addClinicalAssessment + mobile RecoveryService.
      function validAssessment(d) {
        return d.painScore is int && d.painScore >= 0 && d.painScore <= 10 &&
          d.mobilityScore is int && d.mobilityScore >= 0 && d.mobilityScore <= 10 &&
          d.physioNotes is string && d.physioNotes.size() <= 2000 &&
          d.sessionId is string && d.sessionId.size() <= 200;
      }
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create, update: if isAdmin() && validAssessment(request.resource.data);
      allow delete: if isAdmin();
    }

    match /patients/{userId}/people/{personId}/painLogs/{date} {
      allow read, delete: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      // Shape written by lib/recovery.ts logPainScore: { score, note, loggedAt }.
      // score is an integer slider value; loggedAt is a serverTimestamp readers
      // call .toDate() on, so both are typed to keep the recovery views from throwing.
      allow create, update: if (isAdmin() || (isSignedIn() && request.auth.uid == userId)) &&
        request.resource.data.keys().hasOnly(["score", "note", "loggedAt"]) &&
        request.resource.data.score is int &&
        request.resource.data.score >= 0 &&
        request.resource.data.score <= 10 &&
        request.resource.data.note is string &&
        request.resource.data.note.size() <= 500 &&
        request.resource.data.loggedAt is timestamp;
    }

    match /patients/{userId}/people/{personId}/assignedExercises/{exerciseId} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /patients/{userId}/people/{personId}/exerciseLogs/{date} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // Shape written by the mobile blog favourite toggle (blog_screen.dart /
    // blog_detail_screen.dart), via PatientAccountService.favouriteBlogDoc. Every
    // BlogArticle field is a Dart String, so publishedAt is an ISO string, not a
    // timestamp. Writes are a full set() (no merge), so the caps apply to the whole doc.
    // Delete is separate: request.resource is null on delete, so validFavourite
    // would reject every un-favourite if folded into one write rule.
    match /patients/{userId}/favoriteBlogs/{slug} {
      function validFavourite(d) {
        return d.keys().hasOnly(['slug', 'title', 'category', 'excerpt', 'image',
          'publishedAt', 'savedAt', 'userId', 'userEmail']) &&
          d.slug is string && d.slug.size() >= 1 && d.slug.size() <= 200 &&
          d.title is string && d.title.size() <= 300 &&
          d.category is string && d.category.size() <= 100 &&
          d.excerpt is string && d.excerpt.size() <= 2000 &&
          d.image is string && d.image.size() <= 1000 &&
          d.publishedAt is string && d.publishedAt.size() <= 40 &&
          d.savedAt is timestamp &&
          d.userId is string && d.userId == userId &&
          d.userEmail is string && d.userEmail.size() <= 254;
      }
      allow read, delete: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create, update: if (isAdmin() || (isSignedIn() && request.auth.uid == userId)) &&
        validFavourite(request.resource.data);
    }

    // Shape written by the mobile document upload (profile_screen.dart) after the
    // Storage putData succeeds. storage.rules is what actually caps the bytes at 10MB;
    // mirroring the cap here just stops the Firestore record claiming a size the
    // upload never had. `size` is picked.size, a Dart int.
    match /patients/{userId}/uploads/{uploadId} {
      function validUpload(d) {
        return d.keys().hasOnly(['fileName', 'downloadUrl', 'storagePath', 'size',
          'uploadedAt', 'uploadedBy', 'extension']) &&
          d.fileName is string && d.fileName.size() >= 1 && d.fileName.size() <= 255 &&
          d.downloadUrl is string && d.downloadUrl.size() <= 2000 &&
          d.storagePath is string && d.storagePath.size() <= 500 &&
          d.size is int && d.size >= 0 && d.size <= 10 * 1024 * 1024 &&
          d.uploadedAt is timestamp &&
          d.uploadedBy is string && d.uploadedBy.size() <= 254 &&
          d.extension is string && d.extension.size() <= 10;
      }
      allow read, delete: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create, update: if (isAdmin() || (isSignedIn() && request.auth.uid == userId)) &&
        validUpload(request.resource.data);
    }

    // Read-only catch-all. No blanket admin write: overlapping matches grant if ANY
    // allows, so a write rule here would let admin clients skip the validation in the
    // explicit subcollection matches above (e.g. clinicalAssessments caps). Every
    // server-side write (chat transcripts, cal-webhook) uses the Admin SDK shim,
    // which bypasses rules entirely.
    match /patients/{userId}/{document=**} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    // Collection-group rule for the admin chat logs viewer (components/admin-chat-logs.tsx),
    // which runs a collectionGroup("chatSessions") query across all patients/{uid}/chatSessions/{id}.
    // The recursive wildcard under /patients/{userId} above only authorizes per-patient reads,
    // not cross-patient collection-group queries — this is required in addition to it.
    // Read-only: chatSessions are written server-side (app/api/chat via the Admin SDK shim).
    match /{path=**}/chatSessions/{sessionId} {
      allow read: if isAdmin();
    }

    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
