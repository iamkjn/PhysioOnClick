rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.email == "admin@physioonclick.co.uk"
      );
    }

    function ownsEmailResource() {
      return isSignedIn() &&
        resource.data.email is string &&
        request.auth.token.email == resource.data.email;
    }

    match /blogs/{blogId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /pricing/{pricingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /exerciseVideos/{videoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /rehabPrograms/{programId} {
      allow read: if isAdmin() ||
        (isSignedIn() &&
          resource.data.patientEmail is string &&
          request.auth.token.email == resource.data.patientEmail);
      allow create, update, delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      // Bookings are only ever created server-side (Cal.com webhook, appointments/sync,
      // link-bookings), all via the Admin SDK which bypasses these rules. No legitimate
      // client path creates a booking directly, so client-side create is fully denied.
      allow create: if false;
      allow read: if isAdmin() || ownsEmailResource() ||
        (isSignedIn() && resource.data.bookedBy == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /dependents/{dependentId} {
      // Mirrors client-side caps in lib/validation.ts / mobile validators.dart.
      function validDependent(d) {
        return d.name is string && d.name.size() >= 1 && d.name.size() <= 80 &&
          d.dob is string &&
          d.relationship is string &&
          d.notes is string && d.notes.size() <= 500;
      }
      allow read, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.ownerId == request.auth.uid &&
        validDependent(request.resource.data);
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid &&
        validDependent(request.resource.data);
      allow read, write: if isAdmin();
    }

    match /sessionSummaries/{summaryId} {
      // Normally created server-side (publishSummary, Admin SDK bypasses rules);
      // these constraints cover any direct admin-client write path.
      function validSummary(d) {
        return d.workedOn is string && d.workedOn.size() >= 1 && d.workedOn.size() <= 2000 &&
          d.exercises is string && d.exercises.size() >= 1 && d.exercises.size() <= 2000 &&
          d.nextSteps is string && d.nextSteps.size() >= 1 && d.nextSteps.size() <= 2000 &&
          d.sessionOutcome in ['improving', 'stable', 'setback'] &&
          d.recoveryPercent is int && d.recoveryPercent >= 0 && d.recoveryPercent <= 100;
      }
      allow read: if isSignedIn() && (
        isAdmin() ||
        get(/databases/$(database)/documents/bookings/$(resource.data.bookingId)).data.bookedBy == request.auth.uid
      );
      allow create, update: if isAdmin() && validSummary(request.resource.data);
      allow delete: if isAdmin();
    }

    match /pendingSelections/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      // Not currently written or read anywhere in the app (Stripe Checkout doesn't
      // mirror payment records to Firestore). Admin-only until a real writer exists,
      // rather than leaving client-writable "payment succeeded" records unused.
      allow read, write: if isAdmin();
    }

    match /enquiries/{enquiryId} {
      // Public create stays open for the contact form, but the doc must look
      // like a real enquiry — same caps as app/api/enquiry.
      function validNewEnquiry(d) {
        return d.status == 'new' &&
          d.name is string && d.name.size() >= 1 && d.name.size() <= 80 &&
          d.email is string && d.email.size() <= 254 &&
          d.phone is string && d.phone.size() <= 20 &&
          d.message is string && d.message.size() >= 20 && d.message.size() <= 2000;
      }
      allow create: if validNewEnquiry(request.resource.data);
      allow read: if isAdmin() || ownsEmailResource();
      allow update: if isAdmin() &&
        request.resource.data.status in ['new', 'in-progress', 'resolved'];
      allow delete: if isAdmin();
    }

    match /patients/{userId} {
      allow read, update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /patients/{userId}/people/{personId}/clinicalAssessments/{date} {
      // Shape written by lib/recovery.ts addClinicalAssessment + mobile RecoveryService.
      function validAssessment(d) {
        return d.painScore is int && d.painScore >= 0 && d.painScore <= 10 &&
          d.mobilityScore is int && d.mobilityScore >= 0 && d.mobilityScore <= 10 &&
          d.physioNotes is string && d.physioNotes.size() <= 2000 &&
          d.sessionId is string && d.sessionId.size() <= 200;
      }
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create, update: if isAdmin() && validAssessment(request.resource.data);
      allow delete: if isAdmin();
    }

    match /patients/{userId}/people/{personId}/painLogs/{date} {
      allow read, delete: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      // Shape written by lib/recovery.ts logPainScore: { score, note, loggedAt }.
      allow create, update: if (isAdmin() || (isSignedIn() && request.auth.uid == userId)) &&
        request.resource.data.keys().hasOnly(["score", "note", "loggedAt"]) &&
        request.resource.data.score is number &&
        request.resource.data.score >= 0 &&
        request.resource.data.score <= 10 &&
        request.resource.data.note is string &&
        request.resource.data.note.size() <= 500;
    }

    match /patients/{userId}/people/{personId}/assignedExercises/{exerciseId} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /patients/{userId}/people/{personId}/exerciseLogs/{date} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /patients/{userId}/{document=**} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow write: if isAdmin();
    }

    // Collection-group rule for the admin chat logs viewer (components/admin-chat-logs.tsx),
    // which runs a collectionGroup("chatSessions") query across all patients/{uid}/chatSessions/{id}.
    // The recursive wildcard under /patients/{userId} above only authorizes per-patient reads,
    // not cross-patient collection-group queries — this is required in addition to it.
    // Read-only: writes to chatSessions continue to go through patients/{userId}/{document=**} above.
    match /{path=**}/chatSessions/{sessionId} {
      allow read: if isAdmin();
    }

    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
