rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.email == "admin@physioonclick.co.uk"
      );
    }

    function ownsEmailResource() {
      return isSignedIn() &&
        resource.data.email is string &&
        request.auth.token.email == resource.data.email;
    }

    match /blogs/{blogId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /services/{serviceId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /pricing/{pricingId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /exerciseVideos/{videoId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /rehabPrograms/{programId} {
      allow read: if isAdmin() ||
        (isSignedIn() &&
          resource.data.patientEmail is string &&
          request.auth.token.email == resource.data.patientEmail);
      allow create, update, delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      // Bookings are only ever created server-side (Cal.com webhook, appointments/sync,
      // link-bookings), all via the Admin SDK which bypasses these rules. No legitimate
      // client path creates a booking directly, so client-side create is fully denied.
      allow create: if false;
      allow read: if isAdmin() || ownsEmailResource() ||
        (isSignedIn() && resource.data.bookedBy == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /dependents/{dependentId} {
      allow read, update, delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow read, write: if isAdmin();
    }

    match /sessionSummaries/{summaryId} {
      allow read: if isSignedIn() && (
        isAdmin() ||
        get(/databases/$(database)/documents/bookings/$(resource.data.bookingId)).data.bookedBy == request.auth.uid
      );
      allow create, update, delete: if isAdmin();
    }

    match /pendingSelections/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /payments/{paymentId} {
      // Not currently written or read anywhere in the app (Stripe Checkout doesn't
      // mirror payment records to Firestore). Admin-only until a real writer exists,
      // rather than leaving client-writable "payment succeeded" records unused.
      allow read, write: if isAdmin();
    }

    match /enquiries/{enquiryId} {
      allow create: if true;
      allow read: if isAdmin() || ownsEmailResource();
      allow update, delete: if isAdmin();
    }

    match /patients/{userId} {
      allow read, update: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    match /patients/{userId}/people/{personId}/clinicalAssessments/{date} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow write: if isAdmin();
    }

    match /patients/{userId}/people/{personId}/painLogs/{date} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /patients/{userId}/people/{personId}/assignedExercises/{exerciseId} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /patients/{userId}/people/{personId}/exerciseLogs/{date} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /patients/{userId}/{document=**} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow write: if isAdmin();
    }

    // Collection-group rule for the admin chat logs viewer (components/admin-chat-logs.tsx),
    // which runs a collectionGroup("chatSessions") query across all patients/{uid}/chatSessions/{id}.
    // The recursive wildcard under /patients/{userId} above only authorizes per-patient reads,
    // not cross-patient collection-group queries — this is required in addition to it.
    // Read-only: writes to chatSessions continue to go through patients/{userId}/{document=**} above.
    match /{path=**}/chatSessions/{sessionId} {
      allow read: if isAdmin();
    }

    match /admin/{document=**} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
