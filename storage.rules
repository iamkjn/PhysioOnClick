rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.email == "admin@physioonclick.co.uk"
      );
    }

    match /patient-uploads/{userId}/{allPaths=**} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }

    match /exercise-videos/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /blog-images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admin-exports/{allPaths=**} {
      allow read, write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
