rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true ||
        request.auth.token.email == "admin@physioonclick.co.uk"
      );
    }

    // Same allow-list + cap as components/upload-panel.tsx (which is advisory only).
    // Delete is separate: request.resource is null on delete, so the type/size
    // checks would reject every delete if folded into a single write rule.
    match /patient-uploads/{userId}/{allPaths=**} {
      allow read, delete: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
      allow create, update: if (isAdmin() || (isSignedIn() && request.auth.uid == userId)) &&
        request.resource.size <= 10 * 1024 * 1024 &&
        request.resource.contentType in [
          'application/pdf', 'image/png', 'image/jpeg',
          'application/msword',
          'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
        ];
    }

    function isImageUpload() {
      return request.resource.size < 5 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }

    // Mobile app profile avatar: avatars/users/{uid}.jpg — the filename is the owner's uid.
    // Storage rules can't put a literal .jpg after a {wildcard} segment, so match the whole
    // filename and compare it to <uid>.jpg.
    match /avatars/users/{fileName} {
      allow read: if isAdmin() || (isSignedIn() && fileName == request.auth.uid + '.jpg');
      allow write: if (isAdmin() || (isSignedIn() && fileName == request.auth.uid + '.jpg')) && isImageUpload();
    }

    // Mobile app dependent avatar: avatars/dependents/{ownerUid}/{dependentId}.jpg.
    // Storage rules can't read Firestore, so the owner uid is embedded in the path instead.
    match /avatars/dependents/{ownerUid}/{fileName} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == ownerUid);
      allow write: if (isAdmin() || (isSignedIn() && request.auth.uid == ownerUid)) && isImageUpload();
    }

    match /exercise-videos/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /blog-images/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admin-exports/{allPaths=**} {
      allow read, write: if isAdmin();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
