{
  "name": "physioonclick",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next",
    "dev": "next dev",
    "emulators": "PATH=\"/opt/homebrew/opt/openjdk@21/bin:$PATH\" firebase emulators:start --import=./.firebase-emulator-data --export-on-exit",
    "build": "next build",
    "rebuild": "npm run clean && npm run build",
    "seed:firestore": "tsx --env-file=.env.local scripts/seed-firestore.ts",
    "emulator:smoke-test": "tsx --env-file=.env.local scripts/emulator-smoke-test.ts",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@gsap/react": "^2.1.2",
    "@stripe/stripe-js": "^5.6.0",
    "firebase": "^11.5.0",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^10.7.0",
    "gsap": "^3.15.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "next": "^15.5.12",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.1",
    "stripe": "^17.7.0",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.5.12",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.2",
    "vitest": "^4.1.9"
  }
}
